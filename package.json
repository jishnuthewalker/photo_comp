{
  "name": "framecut-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev -w @framecut/desktop",
    "build": "npm run build -w @framecut/desktop",
    "build:web": "npm run build -w @framecut/web",
    "preview:web": "npm run preview -w @framecut/web",
    "test": "vitest run --config packages/shared/vitest.config.ts",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.7.10",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
