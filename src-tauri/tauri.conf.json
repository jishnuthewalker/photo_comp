{
  "productName": "PhotosCompilation",
  "version": "0.1.0",
  "identifier": "com.photoscompilation.app",
  "build": {
    "beforeDevCommand": "npm run dev -w @framecut/desktop",
    "beforeBuildCommand": "npm run build -w @framecut/desktop",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../packages/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "PhotosCompilation",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/ffmpeg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
