{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "PhotosCompilation default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    { "identifier": "fs:scope", "allow": [{ "path": "**" }] },
    "shell:allow-open"
  ]
}
